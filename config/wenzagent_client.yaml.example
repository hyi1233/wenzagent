# WenzAgent Client 配置示例
host: "192.168.1.100"         # 服务器IP地址（必填）
port: 9090                    # 服务器端口
deviceId: ""                  # 设备ID（留空自动生成UUID）
deviceName: "My Laptop"       # 设备显示名称
storagePath: "./data"         # 数据存储目录
logLevel: "info"              # 日志级别: debug|info|warn|error|none
topic: ""                     # 分组主题（可选，留空不分组）
